# Add the Root account to the Access Entries
aws eks create-access-entry --cluster-name node-app-cluster \
    --principal-arn arn:aws:iam::751101364131:root

# Give the Root account Admin permissions
aws eks associate-access-policy --cluster-name node-app-cluster \
    --principal-arn arn:aws:iam::751101364131:root \
    --policy-arn arn:aws:iam::aws:policy/AmazonEKSClusterAdminPolicy \
    --access-scope type=cluster
aws eks associate-access-policy --cluster-name node-app-cluster \
    --principal-arn arn:aws:iam::751101364131:root \
    --policy-arn arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy \
    --access-scope type=cluster
metadata:
  name: node-service
  namespace: default
  annotations:
    service.beta.kubernetes.io/aws-load-balancer-scheme: internet-facing
